{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "outDir": "dist",
    "lib": ["ES2022"],
    "types": ["node"],
    "sourceMap": true,
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["mcp", "utils", "adapters", "tests"],
  "exclude": ["node_modules", "dist"]
}
