{
  "name": "lemma",
  "version": "3.1.2",
  "description": "Senior data-scientist mode + live-notebook tools. Frame, look, leakage-check, baseline, validate honestly.",
  "contextFileName": "AGENTS.md",
  "mcpServers": {
    "lemma": {
      "command": "node",
      "args": [
        "${extensionPath}${/}bin${/}lemma-mcp.mjs",
        "--surface=vscode"
      ],
      "env": {
        "LEMMA_NO_MCP_INSTRUCTIONS": "1"
      },
      "includeTools": [
        "connect", "read", "run", "edit", "inspect"
      ]
    }
  }
}
