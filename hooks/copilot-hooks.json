{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/hooks/copilot-session-start.js\"",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/hooks/copilot-prompt-submit.js\"",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/hooks/copilot-pre-tool-use.js\"",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/hooks/copilot-post-tool-use.js\"",
        "timeoutSec": 5
      }
    ]
  }
}
